<svg width="1200" height="630" viewBox="0 0 1200 630" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background gradient -->
  <rect width="1200" height="630" fill="url(#bgGradient)"/>
  
  <!-- Decorative circles -->
  <circle cx="100" cy="100" r="60" fill="rgba(255,255,255,0.05)"/>
  <circle cx="1100" cy="530" r="80" fill="rgba(255,255,255,0.05)"/>
  <circle cx="950" cy="120" r="50" fill="rgba(255,255,255,0.05)"/>
  
  <!-- Globe icon -->
  <g transform="translate(180, 220)">
    <circle cx="95" cy="95" r="90" stroke="white" stroke-width="8" fill="none" opacity="0.9"/>
    <ellipse cx="95" cy="95" rx="40" ry="90" stroke="white" stroke-width="8" fill="none" opacity="0.9"/>
    <line x1="5" y1="95" x2="185" y2="95" stroke="white" stroke-width="8" opacity="0.9"/>
    <line x1="95" y1="5" x2="95" y2="185" stroke="white" stroke-width="8" opacity="0.9"/>
  </g>
  
  <!-- Text content -->
  <text x="420" y="260" font-family="Manrope, Arial, sans-serif" font-size="90" font-weight="800" fill="white">PayGlobe</text>
  <text x="420" y="340" font-family="Manrope, Arial, sans-serif" font-size="36" font-weight="500" fill="rgba(255,255,255,0.85)">Global Payroll Intelligence</text>
  <text x="420" y="410" font-family="Manrope, Arial, sans-serif" font-size="28" font-weight="400" fill="rgba(255,255,255,0.7)">Configure countries, rules, and geo groups</text>
  <text x="420" y="455" font-family="Manrope, Arial, sans-serif" font-size="28" font-weight="400" fill="rgba(255,255,255,0.7)">for intelligent payroll processing</text>
  
  <!-- Gradient definitions -->
  <defs>
    <linearGradient id="bgGradient" x1="0" y1="0" x2="1200" y2="630">
      <stop offset="0%" style="stop-color:#6366f1;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#4f46e5;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#4338ca;stop-opacity:1" />
    </linearGradient>
  </defs>
</svg>
