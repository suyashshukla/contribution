<svg width="192" height="192" viewBox="0 0 192 192" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background with gradient -->
  <rect width="192" height="192" rx="30" fill="url(#gradient)"/>
  
  <!-- Globe icon -->
  <circle cx="96" cy="96" r="50" stroke="white" stroke-width="6" fill="none"/>
  <ellipse cx="96" cy="96" rx="22" ry="50" stroke="white" stroke-width="6" fill="none"/>
  <line x1="46" y1="96" x2="146" y2="96" stroke="white" stroke-width="6"/>
  <line x1="96" y1="46" x2="96" y2="146" stroke="white" stroke-width="6"/>
  
  <!-- PG letters -->
  <text x="96" y="168" font-family="Manrope, Arial, sans-serif" font-size="36" font-weight="800" fill="white" text-anchor="middle">PG</text>
  
  <!-- Gradient definition -->
  <defs>
    <linearGradient id="gradient" x1="0" y1="0" x2="192" y2="192">
      <stop offset="0%" style="stop-color:#6366f1;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#4338ca;stop-opacity:1" />
    </linearGradient>
  </defs>
</svg>
